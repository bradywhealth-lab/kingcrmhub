// This is your Prisma schema file,
// Elite Multi-Tenant AI-Powered CRM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// MULTI-TENANCY & AUTHENTICATION
// ============================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  plan        String   @default("free") // free, starter, pro, enterprise
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]
  leads       Lead[]
  pipelines   Pipeline[]
  automations Automation[]
  sequences   Sequence[]
  activities  Activity[]
  campaigns   Campaign[]
  integrations Integration[]
  socialAccounts SocialAccount[]
  contentQueue ContentQueue[]
  templates   Template[]
  tags        Tag[]
  customFields CustomField[]
  webhooks    Webhook[]
  aiInsights  AIInsight[]
  aiModels    AIModelConfig[]
  csvUploads  CSVUpload[]
  teamMembers TeamMember[]
  auditLogs   AuditLog[]
  predictiveModels PredictiveModel[]
  carriers    Carrier[]
  carrierDocuments CarrierDocument[]
  scrapeJobs  ScrapeJob[]
  scrapedContacts ScrapedContact[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  avatar       String?
  role         String   @default("member") // owner, admin, member
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  preferences  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  leads        Lead[]
  activities   Activity[]
  sequences    Sequence[]
  teamMember   TeamMember?
  assignments  LeadAssignment[]
  teamActivities TeamActivity[]
  sessions     UserSession[]
}

// ============================================
// LEAD MANAGEMENT
// ============================================

model Lead {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Contact Info
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  company        String?
  title          String?
  website        String?
  linkedin       String?
  address        String?
  city           String?
  state          String?
  zip            String?
  country        String?
  
  // Lead Details
  source         String?  // website, referral, linkedin, facebook, google, manual, api
  status         String   @default("new") // new, contacted, qualified, proposal, negotiation, won, lost
  pipelineStage  String?  // References PipelineStage via raw query
  estimatedValue Float?
  probability    Int?     @default(0)
  
  // AI-Powered Fields
  aiScore        Int      @default(0)  // 0-100 lead quality score
  aiConfidence   Float?   // AI confidence level
  aiInsights     Json?    // AI-generated insights
  aiTags         Json?    // AI-suggested tags
  aiNextAction   String?  // AI-recommended next action
  aiLastAnalyzed DateTime?
  
  // Engagement Tracking
  lastContactedAt DateTime?
  lastRespondedAt DateTime?
  engagementScore Int      @default(0)
  totalInteractions Int    @default(0)
  
  // CSV Upload Tracking
  csvUploadId    String?
  csvUpload      CSVUpload? @relation(fields: [csvUploadId], references: [id], onDelete: SetNull)
  rowNumber      Int?       // Row number in original CSV
  
  // Assignment
  assignedToId   String?
  assignedTo     User?    @relation(fields: [assignedToId], references: [id])
  
  // Custom Fields (stored as JSON)
  customFields   Json?
  
  // Notes & Tags
  notes          Note[]
  tags           LeadTag[]
  
  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  activities     Activity[]
  sequenceEnrollments SequenceEnrollment[]
  pipelineItems  PipelineItem[]
  assignments    LeadAssignment[]
  scoreHistory   LeadScoreHistory[]
  quotes         Quote[]
  messageThreads MessageThread[]
  scrapedContacts ScrapedContact[]
  
  @@index([organizationId])
  @@index([status])
  @@index([aiScore])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  color          String   @default("#6366f1")
  leads          LeadTag[]
  createdAt      DateTime @default(now())
  
  @@unique([organizationId, name])
}

model LeadTag {
  leadId String
  tagId  String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([leadId, tagId])
}

model CustomField {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  type           String   // text, number, select, multiselect, date, boolean
  options        Json?    // For select/multiselect
  required       Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  
  @@unique([organizationId, name])
}

// ============================================
// PIPELINE MANAGEMENT
// ============================================

model Pipeline {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  stages         PipelineStage[]
  items          PipelineItem[]
  isDefault      Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PipelineStage {
  id          String   @id @default(cuid())
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name        String
  color       String   @default("#6366f1")
  order       Int      @default(0)
  probability Int?     // Default probability for this stage
  items       PipelineItem[]
  createdAt   DateTime @default(now())
  
  @@index([pipelineId])
}

model PipelineItem {
  id             String   @id @default(cuid())
  pipelineId     String
  pipeline       Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageId        String
  stage          PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  // Item Details
  title          String
  value          Float?
  probability    Int?
  expectedClose  DateTime?
  position       Int      @default(0)
  
  // AI Predictions
  aiWinProbability Float?
  aiExpectedValue  Float?
  aiRecommendation String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@index([pipelineId])
  @@index([stageId])
}

// ============================================
// AI AUTOMATION & SEQUENCES
// ============================================

model Automation {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  trigger        String   // lead_created, lead_scored, stage_changed, form_submitted, etc.
  triggerConfig  Json?    // Configuration for the trigger
  conditions     Json?    // Conditions to match
  actions        Json     // Array of actions to execute
  isActive       Boolean  @default(true)
  executionCount Int      @default(0)
  lastExecutedAt DateTime?
  logs           AutomationLog[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AutomationLog {
  id           String   @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  triggeredBy  String?  // User ID or system
  entityType   String?  // lead, etc.
  entityId     String?
  input        Json?
  output       Json?
  success      Boolean
  error        String?
  duration     Int?     // ms
  createdAt    DateTime @default(now())
  
  @@index([automationId])
}

model Sequence {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?    @relation(fields: [createdById], references: [id])
  name           String
  description    String?
  type           String   @default("email") // email, sms, mixed
  isActive       Boolean  @default(true)
  steps          SequenceStep[]
  enrollments    SequenceEnrollment[]
  totalEnrolled  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SequenceStep {
  id           String   @id @default(cuid())
  sequenceId   String
  sequence     Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  order        Int
  type         String   // email, sms, task, delay
  delayDays    Int      @default(0)
  delayHours   Int      @default(0)
  subject      String?  // For emails
  content      String
  aiGenerated  Boolean  @default(false)
  createdAt    DateTime @default(now())
  
  @@index([sequenceId])
}

model SequenceEnrollment {
  id         String   @id @default(cuid())
  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  currentStep Int     @default(0)
  status     String   @default("active") // active, completed, paused, unsubscribed
  startedAt  DateTime @default(now())
  nextStepAt DateTime?
  completedAt DateTime?
  
  @@unique([sequenceId, leadId])
}

// ============================================
// ACTIVITY & TIMELINE
// ============================================

model Activity {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  leadId         String?
  lead           Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  type           String   // call, email, sms, meeting, note, status_change, ai_analysis, etc.
  title          String
  description    String?
  metadata       Json?
  
  // AI Enhancement
  aiSummary      String?
  aiSentiment    String?  // positive, neutral, negative
  aiActionItems  Json?
  
  createdAt      DateTime @default(now())
  
  @@index([organizationId])
  @@index([leadId])
  @@index([userId])
  @@index([type])
}

// ============================================
// CAMPAIGNS & CONTENT
// ============================================

model Campaign {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  type           String   // email, social, ads, mixed
  status         String   @default("draft") // draft, active, paused, completed
  startDate      DateTime?
  endDate        DateTime?
  budget         Float?
  metrics        Json?    // impressions, clicks, conversions, etc.
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ContentQueue {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String   // post, article, video, story
  platform       String   // linkedin, twitter, facebook, instagram, tiktok
  title          String?
  content        String
  mediaUrls      Json?
  hashtags       Json?
  aiGenerated    Boolean  @default(false)
  status         String   @default("draft") // draft, scheduled, published, failed
  scheduledFor   DateTime?
  publishedAt    DateTime?
  publishedUrl   String?
  engagement     Json?    // likes, comments, shares, etc.
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SocialAccount {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platform       String   // linkedin, twitter, facebook, instagram, tiktok
  accountId      String
  accountName    String?
  accessToken    String   // Encrypted
  refreshToken   String?  // Encrypted
  tokenExpiresAt DateTime?
  profileData    Json?
  isActive       Boolean  @default(true)
  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([organizationId, platform, accountId])
}

// ============================================
// LEAD SCRAPING + BROKER CARRIER LIBRARY
// ============================================

model ScrapeJob {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name           String?
  sourceUrl      String
  urls           Json?    // array of urls
  type           String   @default("website") // website, directory, sitemap
  status         String   @default("pending") // pending, running, completed, partial, failed
  config         Json?    // maxPages, followLinks, respectRobots, useHeadless, delayMs, selectors
  stats          Json?    // pagesScraped, contactsFound, leadsCreated, duplicates, errors
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contacts       ScrapedContact[]

  @@index([organizationId])
  @@index([status])
}

model ScrapedContact {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scrapeJobId    String
  scrapeJob      ScrapeJob @relation(fields: [scrapeJobId], references: [id], onDelete: Cascade)

  sourceUrl      String
  rawData        Json?
  email          String?
  phone          String?
  firstName      String?
  lastName       String?
  company        String?
  title          String?
  leadId         String?
  lead           Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([scrapeJobId])
  @@index([organizationId])
  @@index([leadId])
}

model Carrier {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name           String
  slug           String
  logoUrl        String?
  website        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  documents      CarrierDocument[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model CarrierDocument {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  carrierId      String
  carrier        Carrier  @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  type           String   // brochure, underwriting_guidelines, application, other
  name           String
  description    String?
  fileUrl        String
  fileType       String?
  fileSize       Int?
  version        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([carrierId])
}

// ============================================
// INTEGRATIONS & SETTINGS
// ============================================

model Integration {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String   // email, calendar, crm, slack, zapier, etc.
  name           String
  config         Json?    // API keys, endpoints, etc. (encrypted)
  credentials    String?  // Encrypted credentials
  isActive       Boolean  @default(true)
  lastSyncedAt   DateTime?
  syncStatus     String?  // synced, error, pending
  syncError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([organizationId, type])
}

model Webhook {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  url            String
  events         Json     // Array of event types
  secret         String?
  isActive       Boolean  @default(true)
  lastTriggeredAt DateTime?
  triggerCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Template {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String   // email, sms, proposal, contract
  name           String
  subject        String?  // For emails
  content        String
  variables      Json?    // Available template variables
  aiGenerated    Boolean  @default(false)
  useCount       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================
// AI CONFIGURATION & LEARNING
// ============================================

model AIModelConfig {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modelType      String   // lead_scoring, content_gen, sentiment, chat
  modelName      String
  config         Json?    // Model parameters
  customPrompts  Json?    // Custom prompts for the organization
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AIInsight {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String   // trend, prediction, recommendation, alert
  category       String?  // leads, pipeline, content, performance
  title          String
  description    String
  data           Json?
  confidence     Float?
  actionable     Boolean  @default(true)
  dismissed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  
  @@index([organizationId])
  @@index([type])
}

model AIFeedback {
  id           String   @id @default(cuid())
  entityType   String   // lead_score, content, insight, chat
  entityId     String
  rating       Int      // 1-5 or -1/1 for thumbs
  feedback     String?
  corrections  Json?    // User corrections for learning
  createdAt    DateTime @default(now())
  
  @@index([entityType])
  @@index([entityId])
}

// ============================================
// CSV UPLOAD TRACKING
// ============================================

model CSVUpload {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // File Information
  fileName       String
  fileSize       Int      // bytes
  fileType       String   // text/csv, etc.
  uploadedBy     String?  // User ID
  
  // Processing Status
  status         String   @default("pending") // pending, processing, completed, failed
  totalRows      Int      @default(0)
  processedRows  Int      @default(0)
  successfulRows Int      @default(0)
  failedRows     Int      @default(0)
  duplicateRows  Int      @default(0)
  
  // Column Mapping
  columnMapping  Json?    // How columns were mapped to lead fields
  
  // Processing Details
  errors         Json?    // Array of error messages with row numbers
  warnings       Json?    // Array of warning messages
  
  // Source info for leads
  defaultSource  String?  // Default lead source for this upload
  
  // AI Processing
  aiAutoScored   Boolean  @default(false) // Whether AI scored all leads
  
  createdAt      DateTime @default(now())
  completedAt    DateTime?
  
  // Relations
  leads          Lead[]
  
  @@index([organizationId])
  @@index([status])
}

// ============================================
// TEAM COLLABORATION (Phase 1)
// ============================================

model TeamMember {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Role & Permissions
  role           String   @default("agent") // owner, admin, agent, viewer
  permissions    Json?    // Custom permissions override
  
  // Assignment Limits
  maxLeads       Int?     // Maximum leads assignable
  currentLeads   Int      @default(0)
  
  // Performance Tracking
  totalLeadsWon  Int      @default(0)
  totalRevenue   Float    @default(0)
  avgResponseTime Int?    // minutes
  
  // Status
  isActive       Boolean  @default(true)
  lastActiveAt   DateTime?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([organizationId, userId])
  @@index([organizationId])
}

model LeadAssignment {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedToId   String
  assignedTo     User     @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedById   String?
  
  // Assignment Details
  reason         String?  // manual, auto_round_robin, auto_score_based
  priority       String   @default("normal") // low, normal, high, urgent
  
  // Status
  status         String   @default("active") // active, transferred, completed
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@index([leadId])
  @@index([assignedToId])
}

model TeamActivity {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type           String   // login, lead_viewed, lead_updated, deal_won, etc.
  description    String
  entityType     String?  // lead, deal, etc.
  entityId       String?
  metadata       Json?
  
  createdAt      DateTime @default(now())
  
  @@index([organizationId])
  @@index([userId])
}

// ============================================
// LEAD SCORING HISTORY (Phase 1 - Predictive Scoring 2.0)
// ============================================

model LeadScoreHistory {
  id             String   @id @default(cuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  // Score Details
  score          Int
  confidence     Float?
  
  // Factors that contributed to score
  factors        Json?    // { email_quality: 15, title_match: 20, etc. }
  
  // AI Model Info
  modelVersion   String?
  modelType      String?  // rule_based, ml_v1, ml_v2
  
  // Context
  triggeredBy    String?  // manual, auto, import
  
  createdAt      DateTime @default(now())
  
  @@index([leadId])
  @@index([createdAt])
}

model PredictiveModel {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name           String
  version        String
  type          String   // win_probability, conversion, churn
  
  // Model Config
  features       Json     // Features used for prediction
  weights        Json?    // Feature weights
  accuracy       Float?   // Model accuracy score
  
  // Training Info
  trainedOn      DateTime?
  trainingSamples Int?
  
  isActive       Boolean  @default(true)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================
// QUOTES & DOCUMENTS (Phase 1)
// ============================================

model Quote {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String?
  lead           Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  // Quote Details
  quoteNumber    String
  title          String
  status         String   @default("draft") // draft, sent, viewed, accepted, rejected, expired
  
  // Pricing
  subtotal       Float    @default(0)
  discount       Float    @default(0)
  tax            Float    @default(0)
  total          Float    @default(0)
  currency       String   @default("USD")
  
  // Validity
  validUntil     DateTime?
  
  // E-Signature
  signatureId    String?
  signedAt       DateTime?
  signedBy       String?
  signedByName   String?
  
  // Tracking
  sentAt         DateTime?
  viewedAt       DateTime?
  viewCount      Int      @default(0)
  
  // AI Generated
  aiGenerated    Boolean  @default(false)
  aiSuggestions  Json?
  
  items          QuoteLineItem[]
  versions       QuoteVersion[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([quoteNumber])
}

model QuoteLineItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  discount    Float    @default(0)
  total       Float
  
  order       Int      @default(0)
  
  @@index([quoteId])
}

model QuoteVersion {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  version     Int
  
  // Snapshot
  content     Json     // Full quote content at this version
  
  // Change info
  changedBy   String?
  changeNote  String?
  
  createdAt   DateTime @default(now())
  
  @@unique([quoteId, version])
}

// ============================================
// UNIFIED MESSAGES (Phase 1 - Omni-Channel Inbox)
// ============================================

model MessageThread {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String?
  lead           Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  // Thread Info
  subject        String?
  lastMessageAt  DateTime @default(now())
  unreadCount    Int      @default(0)
  
  // Participants
  participantEmail String?
  participantPhone String?
  
  // Channel
  primaryChannel String  // email, sms, whatsapp, messenger
  
  // AI
  aiSummary      String?
  aiSentiment    String?
  
  messages       Message[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@index([leadId])
  @@index([organizationId])
}

model Message {
  id             String   @id @default(cuid())
  threadId       String
  thread         MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  // Channel
  channel        String   // email, sms, whatsapp, messenger
  
  // Direction
  direction      String   // inbound, outbound
  status         String   @default("sent") // pending, sent, delivered, read, failed
  
  // Content
  subject        String?
  body           String
  attachments    Json?
  
  // Sender/Recipient
  fromAddress    String?
  fromName       String?
  toAddress      String?
  toName         String?
  
  // Timestamps
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  
  // AI Processing
  aiProcessed    Boolean  @default(false)
  aiCategory     String?  // inquiry, response, spam, etc.
  aiSuggestedReply String?
  
  createdAt      DateTime @default(now())
  
  @@index([threadId])
}

// ============================================
// AUDIT LOG (Phase 1 - Security)
// ============================================

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Action
  action         String   // create, update, delete, view, export, login
  entityType     String   // lead, quote, user, etc.
  entityId       String?
  
  // Changes
  oldValue       Json?
  newValue       Json?
  
  // Actor
  actorId        String?
  actorEmail     String?
  actorIp        String?
  actorUserAgent String?
  
  // Context
  description    String
  metadata       Json?
  
  createdAt      DateTime @default(now())
  
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================
// USER SESSIONS (Phase 1 - Real-time Collaboration)
// ============================================

model UserSession {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Session Info
  token          String   @unique
  device         String?
  browser        String?
  os             String?
  ip             String?
  
  // Location (approximate)
  city           String?
  country        String?
  
  // Status
  isActive       Boolean  @default(true)
  lastActiveAt   DateTime @default(now())
  
  // Currently Viewing
  viewingType    String?  // lead, pipeline, dashboard
  viewingId      String?
  
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  
  @@index([userId])
  @@index([token])
}
